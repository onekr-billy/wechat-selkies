# Ports
HTTP_PORT=3000
HTTPS_PORT=3001

# User/Group
PUID=1000
PGID=100

# Selkies Web UI
# CUSTOM_USER=
# PASSWORD=

# Shared Memory
SHM_SIZE=1gb

# Nightly WeChat Restart Schedule
# ENABLE_WECHAT_NIGHTLY_RESTART=true
# WECHAT_NIGHTLY_STOP_TIME=23:30
# WECHAT_NIGHTLY_START_TIME=01:30

# WeChat Auto-Login on Startup/Restart
# ENABLE_WECHAT_AUTO_LOGIN=true
# AUTO_LOGIN_DELAY=3



